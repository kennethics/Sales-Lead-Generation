    {
      "parameters": {
        "dataTableId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "date": "={{ $now.toISO() }}",
            "targetIndustry": "={{ $(\"Define Search Criteria\").item.json.targetIndustry }}",
            "targetRole": "={{ $(\"Define Search Criteria\").item.json.targetRole }}",
            "totalEmailsSent": "={{ $json.totalEmailsSent }}",
            "status": "={{ $json.status }}",
            "completedAt": "={{ $json.completedAt }}"
          }
        },
        "options": {}
      },
      "id": "29907a1f-99a7-4307-a4c1-318c258e597a",
      "name": "Store Lead Summary",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        -608,
        -2432
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const leads = $input.item.json.output.leads || [];\nreturn leads.map(lead => ({ json: lead }));"
      },
