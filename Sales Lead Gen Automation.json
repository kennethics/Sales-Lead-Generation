    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert lead generation specialist. Your task is to find and qualify potential leads based on the following criteria:\n\nIndustry: {{ $json.targetIndustry }}\nTarget Role: {{ $json.targetRole }}\nLocation: {{ $json.targetLocation }}\nCompany Size: {{ $json.companySize }}\n\nUse the available tools to:\n1. Search for companies and professionals matching these criteria using Perplexity Search\n2. Extract detailed LinkedIn profiles using LinkedIn Scraper (Phantombuster)\n3. Make additional API calls if needed using HTTP Request\n4. Store qualified leads in the data table using Store Lead\n\nFor each lead, gather: name, company, title, email (if available), LinkedIn URL, industry, location, and relevant notes.\nFocus on quality over quantity - only include leads that closely match the criteria.\nProvide a summary of your findings and suggest next steps for outreach.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a professional lead generation agent with access to web search, LinkedIn scraping, HTTP requests, and data storage tools. Always verify information accuracy and prioritize high-quality leads.",
          "maxIterations": 15,
          "returnIntermediateSteps": true
        }
      },
      "id": "0ccb13b4-4163-48e8-9a3b-cb294e50f0c3",
      "name": "Lead Generation Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -2000,
        -2528
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        },
        "builtInTools": {},
        "options": {}
      },
