      ]
    },
    {
      "parameters": {
        "jsonSchemaExample": "{{ { \"leads\": [{ \"name\": \"John Doe\", \"company\": \"Acme Corp\", \"title\": \"VP of Sales\", \"email\": \"john@acme.com\", \"linkedinUrl\": \"https://linkedin.com/in/johndoe\", \"industry\": \"Technology\", \"location\": \"San Francisco, CA\", \"notes\": \"Potential high-value lead\" }], \"summary\": \"Found 5 qualified leads in the technology sector\", \"nextSteps\": \"Follow up with personalized outreach\" } }}"
      },
      "id": "927bebee-17e2-4484-a4d5-c0802d57b527",
      "name": "Lead Data Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
