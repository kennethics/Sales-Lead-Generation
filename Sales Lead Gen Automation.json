        -896,
        -2432
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a personalized outbound email to {{ $json.name }} who is {{ $json.title }} at {{ $json.company }}.\n\nLead Details:\n- Name: {{ $json.name }}\n- Company: {{ $json.company }}\n- Title: {{ $json.title }}\n- Industry: {{ $json.industry }}\n- Location: {{ $json.location }}\n- LinkedIn: {{ $json.linkedinUrl }}\n- Notes: {{ $json.notes }}\n\nTarget Criteria:\n- Industry: {{ $(\"Define Search Criteria\").item.json.targetIndustry }}\n- Role: {{ $(\"Define Search Criteria\").item.json.targetRole }}\n\nCreate a professional, personalized email that:\n1. References their specific role and company\n2. Demonstrates knowledge of their industry\n3. Offers clear value proposition\n4. Includes a soft call-to-action\n5. Keeps it concise (under 150 words)\n\nReturn ONLY the email body text, no subject line.",
        "options": {
          "systemMessage": "You are an expert sales copywriter specializing in personalized B2B outreach. Write compelling, authentic emails that feel personal and valuable, not salesy or generic.",
          "maxIterations": 5,
          "returnIntermediateSteps": false
        }
      },
      "id": "e985e0e5-e958-43b6-b9ef-e29ece75fa17",
      "name": "Compose Personalized Email",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -960,
        -2832
      ]
    },
    {
